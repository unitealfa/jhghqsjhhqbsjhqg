<?xml version="1.0" encoding="utf-8"?>
<package xmlns="http://schemas.microsoft.com/packaging/2013/05/nuspec.xsd">
  <metadata>
    <id>Tmds.DBus.Protocol</id>
    <version>0.92.0</version>
    <authors>Tom Deseyn</authors>
    <license type="expression">MIT</license>
    <licenseUrl>https://licenses.nuget.org/MIT</licenseUrl>
    <icon>icon_128.png</icon>
    <readme>README.md</readme>
    <description>Modern, low-level, high-performance D-Bus library for .NET that is NativeAOT compatible.</description>
    <copyright>Tom Deseyn</copyright>
    <tags>dbus</tags>
    <repository type="git" url="https://github.com/tmds/Tmds.DBus.git" branch="refs/heads/release/0.92" commit="282acebca8d4e4e3ba211646ac650911ee94edfd" />
    <dependencies>
      <group targetFramework="net6.0">
        <dependency id="System.IO.Pipelines" version="8.0.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net8.0">
        <dependency id="System.IO.Pipelines" version="8.0.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework="net9.0">
        <dependency id="System.IO.Pipelines" version="8.0.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETStandard2.0">
        <dependency id="Microsoft.Bcl.AsyncInterfaces" version="8.0.0" exclude="Build,Analyzers" />
        <dependency id="System.IO.Pipelines" version="8.0.0" exclude="Build,Analyzers" />
        <dependency id="System.Threading.Channels" version="8.0.0" exclude="Build,Analyzers" />
      </group>
      <group targetFramework=".NETStandard2.1">
        <dependency id="Microsoft.Bcl.AsyncInterfaces" version="8.0.0" exclude="Build,Analyzers" />
        <dependency id="System.IO.Pipelines" version="8.0.0" exclude="Build,Analyzers" />
        <dependency id="System.Threading.Channels" version="8.0.0" exclude="Build,Analyzers" />
      </group>
    </dependencies>
  </metadata>
</package>