<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="using:EasySave.GUI.ViewModels"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        d:DesignWidth="1460"
        d:DesignHeight="940"
        x:Class="EasySave.GUI.Views.MainWindow"
        x:DataType="vm:MainWindowViewModel"
        Icon="/Assets/avalonia-logo.ico"
        Width="1460"
        Height="940"
        MinWidth="1240"
        MinHeight="820"
        Title="EasySave 2.0">

    <Design.DataContext>
        <vm:MainWindowViewModel />
    </Design.DataContext>

    <Grid RowDefinitions="Auto,*,Auto">
        <Border Grid.Row="0" Classes="xp-menubar">
            <Grid ColumnDefinitions="Auto,* ,Auto" Margin="12,0">
                <TextBlock Text="{Binding Texts[ShellTitle]}" Classes="window-title" VerticalAlignment="Center" />
                <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="20,0,0,0" Spacing="0">
                    <Button Classes="xp-menu-button primary"
                            Content="{Binding Texts[MenuFile]}"
                            Command="{Binding NavigateToSectionCommand}"
                            CommandParameter="0" />
                    <Button Classes="xp-menu-button"
                            Content="{Binding Texts[MenuBackups]}"
                            Command="{Binding NavigateToSectionCommand}"
                            CommandParameter="1" />
                    <Button Classes="xp-menu-button"
                            Content="{Binding Texts[MenuSettings]}"
                            Command="{Binding NavigateToSectionCommand}"
                            CommandParameter="5" />
                    <Button Classes="xp-menu-button"
                            Content="{Binding Texts[MenuHelp]}"
                            Command="{Binding NavigateToSectionCommand}"
                            CommandParameter="5" />
                </StackPanel>
                <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                    <TextBlock Text="◉" Foreground="White" FontSize="14" />
                    <TextBlock Text="?" Foreground="White" FontSize="14" FontWeight="Bold" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="1" Classes="xp-shell" Margin="0">
            <TabControl Classes="xp-shell" TabStripPlacement="Left" SelectedIndex="{Binding SelectedSectionIndex}">
                <TabItem Header="{Binding Texts[DashboardTab]}">
                    <ScrollViewer Margin="10">
                        <Border Classes="xp-card" Padding="0" BorderBrush="#716F64" BorderThickness="1">
                            <Grid RowDefinitions="Auto,*" Background="#F9F9F9">
                                <Border Background="#0058E3" BorderBrush="#003399" BorderThickness="0,0,0,1" Padding="6,5">
                                    <Grid ColumnDefinitions="*,Auto">
                                        <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                            <TextBlock Text=">" Foreground="White" FontWeight="Bold" />
                                            <TextBlock Text="{Binding Texts[DashboardWindowTitle]}" Foreground="White" FontWeight="Bold" FontSize="13" />
                                        </StackPanel>
                                        <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                            <Border Width="20" Height="18" Background="#D4D0C8" BorderBrush="#003399" BorderThickness="1">
                                                <TextBlock Text="_" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" />
                                            </Border>
                                            <Border Width="20" Height="18" Background="#D4D0C8" BorderBrush="#003399" BorderThickness="1">
                                                <TextBlock Text="□" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="9" />
                                            </Border>
                                            <Border Width="20" Height="18" Background="#D9534F" BorderBrush="White" BorderThickness="1">
                                                <TextBlock Text="X" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold" FontSize="10" />
                                            </Border>
                                        </StackPanel>
                                    </Grid>
                                </Border>

                                <StackPanel Grid.Row="1" Margin="16" Spacing="16">
                                    <Grid ColumnDefinitions="*,*,*,*,*" ColumnSpacing="8">
                                        <Border Classes="xp-summary" BorderBrush="#716F64" BorderThickness="1">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Texts[DashboardTotalJobs]}" Classes="metric-caption" />
                                                <TextBlock Text="{Binding TotalJobsCount}" Classes="metric-value" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="1" Classes="xp-summary" BorderBrush="#716F64" BorderThickness="1">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Texts[DashboardLastBackup]}" Classes="metric-caption" />
                                                <TextBlock Text="{Binding LatestBackupText}" Classes="metric-value" Foreground="#1D5CB6" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="2" Classes="xp-summary" BorderBrush="#716F64" BorderThickness="1">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Texts[DashboardGlobalStatus]}" Classes="metric-caption" />
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <Ellipse Width="12" Height="12" Fill="#1D8F2F" Stroke="#0D5E1A" StrokeThickness="1" VerticalAlignment="Center" />
                                                    <TextBlock Text="{Binding GlobalStatusLabel}" FontWeight="Bold" FontSize="20" Foreground="#1D8F2F" />
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="3" Classes="xp-summary" BorderBrush="#716F64" BorderThickness="1">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Texts[DashboardLogFormat]}" Classes="metric-caption" />
                                                <TextBlock Text="{Binding CurrentLogFormatLabel}" Classes="metric-value" Foreground="#1A1C1C" />
                                            </StackPanel>
                                        </Border>
                                        <Border Grid.Column="4" Classes="xp-summary" BorderBrush="#716F64" BorderThickness="1">
                                            <StackPanel Spacing="4">
                                                <TextBlock Text="{Binding Texts[DashboardBusinessSoftware]}" Classes="metric-caption" />
                                                <TextBlock Text="{Binding DashboardBusinessSoftwareRuntimeText}" FontWeight="Bold" Foreground="#BA1A1A" Margin="0,8,0,0" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Border>
                                    </Grid>

                                    <Grid ColumnDefinitions="8*,4*" ColumnSpacing="8" Height="410">
                                        <Border Classes="xp-panel" Padding="0" BorderBrush="#716F64" BorderThickness="1">
                                            <Grid RowDefinitions="Auto,*">
                                                <Border Background="#E2E2E2" BorderBrush="#C3C6D7" BorderThickness="0,0,0,1" Padding="10,6">
                                                    <Grid ColumnDefinitions="*,Auto">
                                                        <TextBlock Text="{Binding Texts[DashboardRecentJobs]}" FontWeight="Bold" FontSize="12" Foreground="#424655" />
                                                        <Button Grid.Column="1"
                                                                Content="{Binding Texts[RefreshJobs]}"
                                                                Command="{Binding RefreshJobsCommand}"
                                                                Padding="6,2"
                                                                MinHeight="22" />
                                                    </Grid>
                                                </Border>
                                                <Grid Grid.Row="1" RowDefinitions="Auto,*">
                                                    <Border Background="#E8E8E8" BorderBrush="#737686" BorderThickness="0,0,0,1" Padding="8,6">
                                                        <Grid ColumnDefinitions="2.3*,1.4*,1.1*,0.9*" ColumnSpacing="0">
                                                            <TextBlock Text="{Binding Texts[DashboardTableJobName]}" FontWeight="Bold" />
                                                            <TextBlock Grid.Column="1" Text="{Binding Texts[DashboardTableStatus]}" FontWeight="Bold" />
                                                            <TextBlock Grid.Column="2" Text="{Binding Texts[DashboardTableCompletion]}" FontWeight="Bold" />
                                                            <TextBlock Grid.Column="3" Text="{Binding Texts[DashboardTableAction]}" FontWeight="Bold" />
                                                        </Grid>
                                                    </Border>
                                                    <ListBox Grid.Row="1"
                                                             Classes="xp-list"
                                                             Background="White"
                                                             BorderThickness="0"
                                                             ItemsSource="{Binding DashboardJobs}">
                                                        <ListBox.ItemTemplate>
                                                            <DataTemplate>
                                                                <Border Classes="xp-row" Padding="8,6">
                                                                    <Grid ColumnDefinitions="2.3*,1.4*,1.1*,0.9*">
                                                                        <TextBlock Text="{Binding Name}" />
                                                                        <TextBlock Grid.Column="1" Text="{Binding Status}" Foreground="#1D8F2F" FontWeight="Bold" />
                                                                        <TextBlock Grid.Column="2" Text="{Binding Completion}" />
                                                                        <Button Grid.Column="3"
                                                                                Content="{Binding $parent[Window].DataContext.Texts[DashboardOpenJob]}"
                                                                                Command="{Binding $parent[Window].DataContext.OpenDashboardJobCommand}"
                                                                                CommandParameter="{Binding Job}"
                                                                                Padding="6,2"
                                                                                MinHeight="22" />
                                                                    </Grid>
                                                                </Border>
                                                            </DataTemplate>
                                                        </ListBox.ItemTemplate>
                                                    </ListBox>
                                                </Grid>
                                            </Grid>
                                        </Border>

                                        <StackPanel Grid.Column="1" Spacing="8">
                                            <Border Classes="xp-panel" BorderBrush="#716F64" BorderThickness="1" Padding="12">
                                                <StackPanel Spacing="10">
                                                    <TextBlock Text="{Binding Texts[DashboardNetworkLoad]}" FontWeight="Bold" FontSize="12" HorizontalAlignment="Center" />
                                                    <Border Background="#E8E8E8" BorderBrush="#C3C6D7" BorderThickness="1" Height="112">
                                                        <StackPanel Margin="12" VerticalAlignment="Center" Spacing="8">
                                                            <TextBlock Text="{Binding DashboardPrimaryGaugeTitle}" HorizontalAlignment="Center" FontWeight="Bold" />
                                                            <ProgressBar Minimum="0" Maximum="100" Value="{Binding SelectedJobProgressValue}" />
                                                            <TextBlock Text="{Binding DashboardPrimaryGaugeValue}"
                                                                       HorizontalAlignment="Center"
                                                                       FontSize="18"
                                                                       FontWeight="Bold"
                                                                       Foreground="#0043B0" />
                                                            <TextBlock Text="{Binding DashboardPrimaryGaugeSubtitle}" HorizontalAlignment="Center" Classes="caption" />
                                                        </StackPanel>
                                                    </Border>
                                                </StackPanel>
                                            </Border>

                                            <Border Classes="xp-panel" BorderBrush="#716F64" BorderThickness="1" Padding="12" Background="#F0F0ED">
                                                <StackPanel Spacing="10">
                                                    <TextBlock Text="{Binding Texts[DashboardOperationControl]}" FontWeight="Bold" FontSize="12" />
                                                    <Grid ColumnDefinitions="*,*" RowDefinitions="Auto,Auto" ColumnSpacing="8" RowSpacing="8">
                                                        <Button Content="{Binding Texts[RunAllJobs]}" Command="{Binding RunAllJobsCommand}" />
                                                        <Button Grid.Column="1" Content="{Binding Texts[JobsTab]}" Command="{Binding NavigateToSectionCommand}" CommandParameter="1" />
                                                        <Button Grid.Row="1" Content="{Binding Texts[SettingsTab]}" Command="{Binding NavigateToSectionCommand}" CommandParameter="5" />
                                                        <Button Grid.Row="1" Grid.Column="1" Content="{Binding Texts[StateTab]}" Command="{Binding NavigateToSectionCommand}" CommandParameter="4" />
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>
                                    </Grid>

                                    <StackPanel Orientation="Horizontal" Spacing="20">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="◷" Foreground="#424655" />
                                            <TextBlock Text="{Binding DashboardFooterCenterText}" Classes="caption" />
                                        </StackPanel>
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <TextBlock Text="⌂" Foreground="#424655" />
                                            <TextBlock Text="{Binding DashboardFooterRightText}" Classes="caption" />
                                        </StackPanel>
                                    </StackPanel>

                                    <Border Classes="xp-alert" BorderBrush="#ACA899" Background="#F0F0ED">
                                        <Grid ColumnDefinitions="2.4*,1.2*" ColumnSpacing="8">
                                            <StackPanel Orientation="Horizontal" Spacing="18">
                                                <TextBlock Text="{Binding Texts[DashboardFooterSystemLog]}" Foreground="#444444" FontWeight="Bold" />
                                                <Button Content="{Binding Texts[DashboardFooterNetworkStatus]}" Command="{Binding NavigateToSectionCommand}" CommandParameter="4" Padding="0" Background="Transparent" BorderThickness="0" Foreground="#444444" />
                                                <Button Content="{Binding Texts[DashboardFooterMedia]}" Command="{Binding NavigateToSectionCommand}" CommandParameter="5" Padding="0" Background="Transparent" BorderThickness="0" Foreground="#444444" />
                                            </StackPanel>
                                            <TextBlock Grid.Column="1"
                                                       Text="{Binding Texts[DashboardFooterCopyright]}"
                                                       HorizontalAlignment="Right"
                                                       Classes="caption" />
                                        </Grid>
                                    </Border>
                                </StackPanel>
                            </Grid>
                        </Border>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="{Binding Texts[JobsTab]}">
                    <Grid>
                    <ScrollViewer Margin="10">
                        <StackPanel Spacing="14">
                            <Border Classes="xp-card" Padding="0" BorderBrush="#003399" BorderThickness="1">
                                <Grid RowDefinitions="Auto,Auto,*,Auto" Background="#ECE9D8">
                                    <Border Background="#0058E3" BorderBrush="#003399" BorderThickness="0,0,0,1" Padding="6,5">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                <TextBlock Text=">" Foreground="White" FontWeight="Bold" />
                                                <TextBlock Text="{Binding Texts[JobsWindowTitle]}" Foreground="White" FontWeight="Bold" FontSize="13" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                                <Border Width="20" Height="18" Background="#D4D0C8" BorderBrush="#003399" BorderThickness="1">
                                                    <TextBlock Text="_" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" />
                                                </Border>
                                                <Border Width="20" Height="18" Background="#D4D0C8" BorderBrush="#003399" BorderThickness="1">
                                                    <TextBlock Text="□" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="9" />
                                                </Border>
                                                <Border Width="20" Height="18" Background="#D9534F" BorderBrush="White" BorderThickness="1">
                                                    <TextBlock Text="X" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold" FontSize="10" />
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="1" Background="#F0F0ED" BorderBrush="#ACA899" BorderThickness="0,0,0,1" Padding="8">
                                        <Grid ColumnDefinitions="Auto,*,Auto" ColumnSpacing="8">
                                            <Button Content="{Binding Texts[RunAllJobsToolbar]}" Command="{Binding RunAllJobsCommand}" />
                                            <Border Grid.Column="2" Background="White" BorderBrush="#ACA899" BorderThickness="1" Padding="8,4">
                                                <Grid ColumnDefinitions="Auto,*" ColumnSpacing="6">
                                                    <TextBlock Text="⌕" Foreground="#7D7D7D" VerticalAlignment="Center" />
                                                    <TextBox Grid.Column="1"
                                                             Background="Transparent"
                                                             BorderThickness="0"
                                                             PlaceholderText="{Binding Texts[JobsFilterPlaceholder]}"
                                                             Text="{Binding JobFilterText}" />
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="2" Margin="10" Background="White" BorderBrush="#716F64" BorderThickness="1" Padding="0">
                                        <Grid RowDefinitions="Auto,*">
                                            <Border Background="#F0F0ED" BorderBrush="#ACA899" BorderThickness="0,0,0,1" Padding="10,8">
                                                <Grid ColumnDefinitions="1.25*,1.8*,1.8*,0.8*,1.15*,0.9*,0.95*" ColumnSpacing="10">
                                                    <TextBlock Text="{Binding Texts[ColumnName]}" Classes="label" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Texts[ColumnSource]}" Classes="label" />
                                                    <TextBlock Grid.Column="2" Text="{Binding Texts[ColumnTarget]}" Classes="label" />
                                                    <TextBlock Grid.Column="3" Text="{Binding Texts[ColumnType]}" Classes="label" />
                                                    <TextBlock Grid.Column="4" Text="{Binding Texts[JobsLastRunColumn]}" Classes="label" />
                                                    <TextBlock Grid.Column="5" Text="{Binding Texts[ColumnStatus]}" Classes="label" />
                                                    <TextBlock Grid.Column="6" Text="{Binding Texts[JobsActionsColumn]}" Classes="label" />
                                                </Grid>
                                            </Border>

                                            <ListBox Grid.Row="1"
                                                     Classes="xp-list"
                                                     Background="White"
                                                     BorderThickness="0"
                                                     ItemsSource="{Binding JobListRows}"
                                                     SelectedValue="{Binding SelectedJob}"
                                                     SelectedValueBinding="{Binding Job}">
                                                <ListBox.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border Classes="xp-row" Padding="10,8">
                                                            <Grid ColumnDefinitions="1.25*,1.8*,1.8*,0.8*,1.15*,0.9*,0.95*" ColumnSpacing="10">
                                                                <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#0043B0" />
                                                                <TextBlock Grid.Column="1" Text="{Binding Source}" TextWrapping="Wrap" />
                                                                <TextBlock Grid.Column="2" Text="{Binding Destination}" TextWrapping="Wrap" />
                                                                <Border Grid.Column="3" Classes="xp-badge">
                                                                    <TextBlock Text="{Binding Type}" HorizontalAlignment="Center" />
                                                                </Border>
                                                                <TextBlock Grid.Column="4" Text="{Binding LastRun}" />
                                                                <TextBlock Grid.Column="5" Text="{Binding Status}" FontWeight="Bold" />
                                                                <StackPanel Grid.Column="6" Orientation="Horizontal" Spacing="6">
                                                                    <Button Content="{Binding $parent[Window].DataContext.Texts[RunJobNow]}"
                                                                            Command="{Binding $parent[Window].DataContext.RunDashboardJobCommand}"
                                                                            CommandParameter="{Binding Job}"
                                                                            Padding="6,2"
                                                                            MinHeight="22" />
                                                                    <Button Content="{Binding $parent[Window].DataContext.Texts[EditJobAction]}"
                                                                            Command="{Binding $parent[Window].DataContext.EditJobCommand}"
                                                                            CommandParameter="{Binding Job}"
                                                                            Padding="6,2"
                                                                            MinHeight="22" />
                                                                    <Button Content="{Binding $parent[Window].DataContext.Texts[DashboardOpenJob]}"
                                                                            Command="{Binding $parent[Window].DataContext.OpenDashboardJobCommand}"
                                                                            CommandParameter="{Binding Job}"
                                                                            Padding="6,2"
                                                                            MinHeight="22" />
                                                                </StackPanel>
                                                            </Grid>
                                                        </Border>
                                                    </DataTemplate>
                                                </ListBox.ItemTemplate>
                                            </ListBox>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="3" Background="#ECE9D8" Padding="10,6" BorderBrush="#ACA899" BorderThickness="0,1,0,0">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                            <TextBlock Text="{Binding JobsSelectedCountText}" Classes="caption" />
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                                <Ellipse Width="9" Height="9" Fill="#1D8F2F" Stroke="#0D5E1A" StrokeThickness="1" VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding JobsServiceStatusText}" Classes="caption" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>

                            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="10">
                                <Border Classes="xp-summary">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding Texts[JobsSummaryTotal]}" Classes="metric-caption" />
                                        <TextBlock Text="{Binding TotalJobsCount}" Classes="metric-value" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Classes="xp-summary">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding Texts[JobsSummaryFiltered]}" Classes="metric-caption" />
                                        <TextBlock Text="{Binding FilteredJobsCount}" Classes="metric-value" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Classes="xp-summary">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding Texts[JobsSummaryActive]}" Classes="metric-caption" />
                                        <TextBlock Text="{Binding ActiveStatesCount}" Classes="metric-value" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="3" Classes="xp-summary">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding Texts[JobsSummaryStorage]}" Classes="metric-caption" />
                                        <ProgressBar Minimum="0" Maximum="100" Value="{Binding JobsStorageUsagePercent}" />
                                        <TextBlock Text="{Binding JobsStorageUsageText}" Classes="caption" />
                                    </StackPanel>
                                </Border>
                            </Grid>

                            <Grid ColumnDefinitions="*,Auto">
                                <TextBlock Text="{Binding Texts[JobsPageSubtitle]}"
                                           Classes="caption"
                                           VerticalAlignment="Center"
                                           TextWrapping="Wrap" />
                                <Button Grid.Column="1"
                                        Content="{Binding Texts[JobsNewJobButton]}"
                                        Command="{Binding PrepareCreateJobCommand}"
                                        Classes="xp-primary"
                                        HorizontalAlignment="Right"
                                        MinWidth="150"
                                        MinHeight="38"
                                        Padding="18,8" />
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                    <Border Background="#66000000"
                            IsVisible="{Binding IsJobFormOverlayVisible}">
                        <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Margin="24">
                            <Border Width="560" Classes="xp-card" Padding="0" BorderBrush="#0058E3" BorderThickness="3">
                                <Grid RowDefinitions="Auto,*" Background="#ECE9D8">
                                    <Border Background="#0058E3" Padding="6,5">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                <TextBlock Text=">" Foreground="White" FontWeight="Bold" />
                                                <TextBlock Text="{Binding JobFormTitle}" Foreground="White" FontWeight="Bold" FontSize="13" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                                <Button Width="21"
                                                        Height="21"
                                                        Background="#2769E5"
                                                        BorderBrush="#FFFFFF66"
                                                        BorderThickness="1"
                                                        IsEnabled="False">
                                                    <TextBlock Text="_" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" />
                                                </Button>
                                                <Button Width="24"
                                                        Height="24"
                                                        Content="×"
                                                        Foreground="White"
                                                        FontSize="14"
                                                        FontWeight="Bold"
                                                        Padding="0"
                                                        HorizontalContentAlignment="Center"
                                                        VerticalContentAlignment="Center"
                                                        Background="#E81123"
                                                        BorderBrush="#FFFFFF66"
                                                        BorderThickness="1"
                                                        Command="{Binding CloseJobFormOverlayCommand}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Row="1" Margin="16" Spacing="12">
                                        <TextBlock Text="{Binding JobFormSubtitle}" Classes="caption" TextWrapping="Wrap" />

                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding Texts[JobName]}" Classes="label" />
                                            <TextBox Text="{Binding JobName}" />
                                        </StackPanel>

                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding Texts[SourceDirectory]}" Classes="label" />
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                <TextBox Text="{Binding SourceDirectory}" />
                                                <Button Grid.Column="1" Content="{Binding Texts[Browse]}" Click="SourceBrowse_Click" />
                                            </Grid>
                                            <TextBlock Text="{Binding Texts[EditJobSourceHint]}" Classes="caption" TextWrapping="Wrap" />
                                        </StackPanel>

                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding Texts[TargetDirectory]}" Classes="label" />
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                <TextBox Text="{Binding TargetDirectory}" />
                                                <Button Grid.Column="1" Content="{Binding Texts[Browse]}" Click="TargetBrowse_Click" />
                                            </Grid>
                                        </StackPanel>

                                        <Border Classes="xp-card" Padding="12">
                                            <StackPanel Spacing="8">
                                                <TextBlock Text="{Binding Texts[BackupTypeField]}" Foreground="#003399" FontWeight="Bold" />
                                                <ComboBox ItemsSource="{Binding BackupTypeOptions}"
                                                          SelectedValue="{Binding SelectedBackupType}"
                                                          SelectedValueBinding="{Binding Value}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Label}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </StackPanel>
                                        </Border>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                            <Button Content="{Binding SaveJobButtonText}" Command="{Binding AddJobCommand}" Classes="xp-primary" />
                                            <Button Content="{Binding Texts[CancelJobEdition]}" Command="{Binding CloseJobFormOverlayCommand}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>
                    </Grid>
                </TabItem>

                <TabItem Header="{Binding Texts[CreateJobTab]}" IsVisible="False">
                    <ScrollViewer Margin="10">
                        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border Width="520" Classes="xp-card" Padding="0" BorderBrush="#0058E3" BorderThickness="3">
                                <Grid RowDefinitions="Auto,*" Background="#ECE9D8">
                                    <Border Background="#0058E3" Padding="6,5">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                <TextBlock Text=">" Foreground="White" FontWeight="Bold" />
                                                <TextBlock Text="{Binding JobFormTitle}" Foreground="White" FontWeight="Bold" FontSize="13" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                                <Button Width="21" Height="21" Background="#2769E5" BorderBrush="#FFFFFF66" BorderThickness="1" IsEnabled="False">
                                                    <TextBlock Text="_" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" />
                                                </Button>
                                                <Button Width="24"
                                                        Height="24"
                                                        Content="×"
                                                        Foreground="White"
                                                        FontSize="14"
                                                        FontWeight="Bold"
                                                        Padding="0"
                                                        HorizontalContentAlignment="Center"
                                                        VerticalContentAlignment="Center"
                                                        Background="#E81123"
                                                        BorderBrush="#FFFFFF66"
                                                        BorderThickness="1"
                                                        Command="{Binding CloseJobFormOverlayCommand}" />
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Row="1" Margin="16" Spacing="12">
                                        <TextBlock Text="{Binding JobFormSubtitle}" Classes="caption" TextWrapping="Wrap" />

                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding Texts[JobName]}" Classes="label" />
                                            <TextBox Text="{Binding JobName}" />
                                        </StackPanel>

                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding Texts[SourceDirectory]}" Classes="label" />
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                <TextBox Text="{Binding SourceDirectory}" />
                                                <Button Grid.Column="1" Content="{Binding Texts[Browse]}" Click="SourceBrowse_Click" />
                                            </Grid>
                                            <TextBlock Text="{Binding Texts[EditJobSourceHint]}" Classes="caption" TextWrapping="Wrap" />
                                        </StackPanel>

                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding Texts[TargetDirectory]}" Classes="label" />
                                            <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                                <TextBox Text="{Binding TargetDirectory}" />
                                                <Button Grid.Column="1" Content="{Binding Texts[Browse]}" Click="TargetBrowse_Click" />
                                            </Grid>
                                        </StackPanel>

                                        <Border Classes="xp-card" Padding="12">
                                            <StackPanel Spacing="8">
                                                <TextBlock Text="{Binding Texts[BackupTypeField]}" Foreground="#003399" FontWeight="Bold" />
                                                <ComboBox ItemsSource="{Binding BackupTypeOptions}"
                                                          SelectedValue="{Binding SelectedBackupType}"
                                                          SelectedValueBinding="{Binding Value}">
                                                    <ComboBox.ItemTemplate>
                                                        <DataTemplate>
                                                            <TextBlock Text="{Binding Label}" />
                                                        </DataTemplate>
                                                    </ComboBox.ItemTemplate>
                                                </ComboBox>
                                            </StackPanel>
                                        </Border>

                                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Spacing="8">
                                            <Button Content="{Binding SaveJobButtonText}" Command="{Binding AddJobCommand}" Classes="xp-primary" />
                                            <Button Content="{Binding Texts[CancelJobEdition]}" Command="{Binding CloseJobFormOverlayCommand}" />
                                        </StackPanel>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="{Binding Texts[ExecutionTab]}">
                    <ScrollViewer Margin="10">
                        <StackPanel Spacing="14">
                            <Border Classes="xp-card" Padding="0" BorderBrush="#003399" BorderThickness="1">
                                <Grid RowDefinitions="Auto,*" Background="#F9F9F9">
                                    <Border Background="#0058E3" BorderBrush="#003399" BorderThickness="0,0,0,1" Padding="6,5">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                <TextBlock Text=">" Foreground="White" FontWeight="Bold" />
                                                <TextBlock Text="{Binding Texts[ExecutionWindowTitle]}" Foreground="White" FontWeight="Bold" FontSize="13" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                                <Border Width="20" Height="18" Background="#D4D0C8" BorderBrush="#003399" BorderThickness="1">
                                                    <TextBlock Text="_" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" />
                                                </Border>
                                                <Border Width="20" Height="18" Background="#D4D0C8" BorderBrush="#003399" BorderThickness="1">
                                                    <TextBlock Text="□" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="9" />
                                                </Border>
                                                <Border Width="20" Height="18" Background="#D9534F" BorderBrush="White" BorderThickness="1">
                                                    <TextBlock Text="X" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold" FontSize="10" />
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Row="1" Margin="16" Spacing="14">
                                        <Grid ColumnDefinitions="74,*" ColumnSpacing="12">
                                            <Border Background="#E8E8E8" BorderBrush="#C3C6D7" BorderThickness="1" Width="74" Height="74">
                                                <TextBlock Text="↻" FontSize="34" Foreground="#0043B0" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                            </Border>
                                            <StackPanel Grid.Column="1" Spacing="4" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding SelectedJobName}" FontWeight="Bold" FontSize="18" Foreground="#0043B0" />
                                                <TextBlock Text="{Binding Texts[ExecutionCurrentFileLabel]}" Classes="label" />
                                                <TextBlock Text="{Binding SelectedJobCurrentSource}" TextWrapping="Wrap" />
                                            </StackPanel>
                                        </Grid>

                                        <Border Classes="xp-panel" Background="#F3F3F3" BorderBrush="#C3C6D7" BorderThickness="1" Padding="10">
                                            <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="8">
                                                <TextBlock Text="{Binding Texts[ColumnSource]}" Classes="label" Foreground="#1D5CB6" />
                                                <TextBlock Grid.Column="1" Text="{Binding SelectedJobSource}" TextWrapping="Wrap" />
                                                <TextBlock Grid.Row="1" Text="{Binding Texts[ColumnTarget]}" Classes="label" Foreground="#1D5CB6" />
                                                <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SelectedJobTarget}" TextWrapping="Wrap" />
                                            </Grid>
                                        </Border>

                                        <StackPanel Spacing="4">
                                            <Grid ColumnDefinitions="*,Auto">
                                                <TextBlock Text="{Binding Texts[ProgressLabel]}" FontWeight="Bold" />
                                                <TextBlock Grid.Column="1" Text="{Binding SelectedJobProgressText}" FontWeight="Bold" />
                                            </Grid>
                                            <ProgressBar Minimum="0" Maximum="100" Value="{Binding SelectedJobProgressValue}" Height="22" />
                                        </StackPanel>

                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                            <Border Classes="xp-summary">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="{Binding Texts[ExecutionFilesCard]}" Classes="metric-caption" />
                                                    <TextBlock Text="{Binding SelectedJobRemainingFilesText}" Classes="metric-value" />
                                                    <TextBlock Text="{Binding SelectedJobTotalFilesText, StringFormat='{}/ {0}'}" Classes="caption" />
                                                </StackPanel>
                                            </Border>
                                            <Border Grid.Column="1" Classes="xp-summary">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="{Binding Texts[ExecutionSizeCard]}" Classes="metric-caption" />
                                                    <TextBlock Text="{Binding SelectedJobRemainingSizeText}" Classes="metric-value" />
                                                    <TextBlock Text="{Binding SelectedJobTotalSizeText, StringFormat='{}/ {0}'}" Classes="caption" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <Grid ColumnDefinitions="*,Auto,*" ColumnSpacing="12">
                                            <StackPanel>
                                                <TextBlock Text="{Binding Texts[StateLabel]}" Classes="metric-caption" HorizontalAlignment="Center" />
                                                <TextBlock Text="{Binding SelectedJobStateLabel}" Foreground="#0043B0" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" />
                                            </StackPanel>
                                            <Border Width="1" Background="#C3C6D7" />
                                            <StackPanel Grid.Column="2">
                                                <TextBlock Text="{Binding Texts[LastUpdateLabel]}" Classes="metric-caption" HorizontalAlignment="Center" />
                                                <TextBlock Text="{Binding SelectedJobLastUpdateText}" Foreground="#0043B0" FontWeight="Bold" FontSize="18" HorizontalAlignment="Center" />
                                            </StackPanel>
                                        </Grid>

                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="12">
                                            <Border Classes="xp-panel" Padding="10">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="{Binding Texts[ExecutionSelectedControlsTitle]}" Classes="panel-title" />
                                                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                                                        <Button Content="{Binding Texts[PlayJob]}" Command="{Binding RunSelectedJobCommand}" Classes="xp-primary" />
                                                        <Button Grid.Column="1" Content="{Binding Texts[PauseJob]}" Command="{Binding PauseSelectedJobCommand}" />
                                                        <Button Grid.Column="2" Content="{Binding Texts[StopJob]}" Command="{Binding StopSelectedJobCommand}" />
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                            <Border Grid.Column="1" Classes="xp-panel" Padding="10">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="{Binding Texts[ExecutionAllControlsTitle]}" Classes="panel-title" />
                                                    <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                                                        <Button Content="{Binding Texts[PlayAllJobs]}" Command="{Binding RunAllJobsCommand}" Classes="xp-primary" />
                                                        <Button Grid.Column="1" Content="{Binding Texts[PauseAllJobs]}" Command="{Binding PauseAllJobsCommand}" />
                                                        <Button Grid.Column="2" Content="{Binding Texts[StopAllJobs]}" Command="{Binding StopAllJobsCommand}" />
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </StackPanel>
                                </Grid>
                            </Border>

                            <Border Classes="xp-error" IsVisible="{Binding IsBusinessSoftwareDetected}">
                                <StackPanel Spacing="6">
                                    <TextBlock Text="{Binding Texts[ExecutionBusinessSoftwareTitle]}" Classes="panel-title" />
                                    <TextBlock Text="{Binding ExecutionBusinessSoftwareAlertText}" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="10">
                                <Border Classes="xp-summary">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding Texts[TotalFilesMetric]}" Classes="metric-caption" />
                                        <TextBlock Text="{Binding SelectedJobTotalFilesText}" Classes="metric-value" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="1" Classes="xp-summary">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding Texts[RemainingFilesMetric]}" Classes="metric-caption" />
                                        <TextBlock Text="{Binding SelectedJobRemainingFilesText}" Classes="metric-value" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="2" Classes="xp-summary">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding Texts[TotalSizeMetric]}" Classes="metric-caption" />
                                        <TextBlock Text="{Binding SelectedJobTotalSizeText}" Classes="metric-value" />
                                    </StackPanel>
                                </Border>
                                <Border Grid.Column="3" Classes="xp-summary">
                                    <StackPanel Spacing="4">
                                        <TextBlock Text="{Binding Texts[RemainingSizeMetric]}" Classes="metric-caption" />
                                        <TextBlock Text="{Binding SelectedJobRemainingSizeText}" Classes="metric-value" />
                                    </StackPanel>
                                </Border>
                            </Grid>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="{Binding Texts[LogsTab]}" IsVisible="False">
                    <ScrollViewer Margin="10">
                        <StackPanel Spacing="14">
                            <Border Classes="xp-card" Padding="0" BorderBrush="#003399" BorderThickness="1">
                                <Grid RowDefinitions="Auto,Auto,*,Auto" Background="#ECE9D8">
                                    <Border Background="#0058E3" BorderBrush="#003399" BorderThickness="0,0,0,1" Padding="6,5">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                <TextBlock Text=">" Foreground="White" FontWeight="Bold" />
                                                <TextBlock Text="{Binding Texts[LogsWindowTitle]}" Foreground="White" FontWeight="Bold" FontSize="13" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                                <Border Width="20" Height="18" Background="#D4D0C8" BorderBrush="#003399" BorderThickness="1">
                                                    <TextBlock Text="_" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" />
                                                </Border>
                                                <Border Width="20" Height="18" Background="#D4D0C8" BorderBrush="#003399" BorderThickness="1">
                                                    <TextBlock Text="□" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="9" />
                                                </Border>
                                                <Border Width="20" Height="18" Background="#D9534F" BorderBrush="White" BorderThickness="1">
                                                    <TextBlock Text="X" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White" FontWeight="Bold" FontSize="10" />
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="1" Background="#F0F0ED" BorderBrush="#ACA899" BorderThickness="0,0,0,1" Padding="8">
                                        <Grid ColumnDefinitions="Auto,Auto,*,Auto" ColumnSpacing="10">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{Binding Texts[LogsViewModeLabel]}" Classes="label" VerticalAlignment="Center" />
                                                <Border Classes="xp-badge">
                                                    <TextBlock Text="{Binding CurrentLogFormatLabel}" />
                                                </Border>
                                            </StackPanel>

                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                                <TextBlock Text="{Binding Texts[LogsCurrentFileLabel]}" Classes="label" VerticalAlignment="Center" />
                                                <TextBlock Text="{Binding LogPreviewPath}" VerticalAlignment="Center" />
                                            </StackPanel>

                                            <Button Grid.Column="3"
                                                    Content="{Binding Texts[LogsRefreshButton]}"
                                                    Command="{Binding RefreshStatesCommand}"
                                                    Classes="xp-primary"
                                                    Padding="10,3"
                                                    MinHeight="24" />
                                        </Grid>
                                    </Border>

                                    <Grid Grid.Row="2" ColumnDefinitions="1.05*,1.75*" ColumnSpacing="12" Margin="12">
                                        <StackPanel Spacing="12">
                                            <Border Classes="xp-card">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="{Binding Texts[LogsCurrentConfigTitle]}" Classes="panel-title" />
                                                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="6">
                                                        <TextBlock Text="{Binding Texts[LogFormatLabel]}" Classes="label" />
                                                        <TextBlock Grid.Column="1" Text="{Binding CurrentLogFormatLabel}" />
                                                        <TextBlock Grid.Row="1" Text="{Binding Texts[LogsDirectoryLabel]}" Classes="label" />
                                                        <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding LogDirectoryPath}" TextWrapping="Wrap" />
                                                        <TextBlock Grid.Row="2" Text="{Binding Texts[LogsCurrentFileLabel]}" Classes="label" />
                                                        <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding LogPreviewPath}" TextWrapping="Wrap" />
                                                    </Grid>
                                                </StackPanel>
                                            </Border>

                                            <Border Classes="xp-alert">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="{Binding Texts[LogsPreviewInfoTitle]}" Classes="panel-title" />
                                                    <TextBlock Text="{Binding LogPreviewInfo}" Classes="caption" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>

                                            <Border Classes="xp-card">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="{Binding Texts[LogsPageTitle]}" Classes="panel-title" />
                                                    <TextBlock Text="{Binding Texts[LogsPageSubtitle]}" Classes="caption" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>
                                        </StackPanel>

                                        <Border Grid.Column="1" Classes="xp-notepad" Padding="0">
                                            <Grid RowDefinitions="Auto,Auto,*">
                                                <Border Background="#F0F0ED" BorderBrush="#ACA899" BorderThickness="0,0,0,1" Padding="8,6">
                                                    <TextBlock Text="{Binding Texts[LogsPreviewFileBanner]}" FontWeight="Bold" />
                                                </Border>
                                                <Border Grid.Row="1" Background="#F0F0ED" BorderBrush="#ACA899" BorderThickness="0,0,0,1" Padding="6,2">
                                                    <StackPanel Orientation="Horizontal" Spacing="16">
                                                        <TextBlock Text="{Binding Texts[LogsNotepadFile]}" />
                                                        <TextBlock Text="{Binding Texts[LogsNotepadEdit]}" />
                                                        <TextBlock Text="{Binding Texts[LogsNotepadSearch]}" />
                                                        <TextBlock Text="{Binding Texts[LogsNotepadHelp]}" />
                                                    </StackPanel>
                                                </Border>
                                                <TextBox Grid.Row="2"
                                                         Classes="xp-logbox"
                                                         Text="{Binding LogPreviewText}"
                                                         Height="540"
                                                         AcceptsReturn="True"
                                                         IsReadOnly="True"
                                                         TextWrapping="NoWrap" />
                                            </Grid>
                                        </Border>
                                    </Grid>

                                    <Border Grid.Row="3" Background="#ECE9D8" Padding="10,6" BorderBrush="#ACA899" BorderThickness="0,1,0,0">
                                        <Grid ColumnDefinitions="Auto,*" ColumnSpacing="8">
                                            <TextBlock Text="{Binding Texts[LogsFooterCount]}" Classes="caption" />
                                            <TextBlock Grid.Column="1" Text="{Binding LogPreviewInfo}" Classes="caption" HorizontalAlignment="Right" />
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="{Binding Texts[StateTab]}">
                    <ScrollViewer Margin="10">
                        <StackPanel Spacing="14">
                            <Border Classes="xp-card" Padding="0" BorderBrush="#003399" BorderThickness="1">
                                <Grid RowDefinitions="Auto,Auto,*,Auto" Background="#ECE9D8">
                                    <Border Background="#0058E3" BorderBrush="#003399" BorderThickness="0,0,0,1" Padding="6,5">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                <TextBlock Text=">" Foreground="White" FontWeight="Bold" />
                                                <TextBlock Text="{Binding Texts[StateWindowTitle]}" Foreground="White" FontWeight="Bold" FontSize="13" />
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Content="{Binding Texts[RefreshState]}"
                                                    Command="{Binding RefreshStatesCommand}"
                                                    Classes="xp-primary"
                                                    Padding="10,3"
                                                    MinHeight="24" />
                                        </Grid>
                                    </Border>

                                    <Border Grid.Row="1" Background="#F0F0ED" BorderBrush="#ACA899" BorderThickness="0,0,0,1" Padding="8">
                                        <Grid ColumnDefinitions="Auto,Auto,Auto,*" ColumnSpacing="10">
                                            <Border Classes="xp-badge success">
                                                <TextBlock Text="{Binding ActiveStatesCount, StringFormat='Actifs: {0}'}" FontWeight="Bold" />
                                            </Border>
                                            <Border Grid.Column="1" Classes="xp-badge">
                                                <TextBlock Text="{Binding FinishedStatesCount, StringFormat='Terminés: {0}'}" FontWeight="Bold" />
                                            </Border>
                                            <Border Grid.Column="2" Classes="xp-badge warning">
                                                <TextBlock Text="{Binding ErrorStatesCount, StringFormat='Erreurs: {0}'}" FontWeight="Bold" />
                                            </Border>
                                            <TextBlock Grid.Column="3" Text="{Binding Texts[StatePageSubtitle]}" Classes="caption" HorizontalAlignment="Right" VerticalAlignment="Center" />
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Row="2" Margin="12" Spacing="12">
                                        <Grid ColumnDefinitions="*,*,*,*" ColumnSpacing="10">
                                            <Border Classes="xp-summary">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="{Binding Texts[JobsSummaryTotal]}" Classes="metric-caption" />
                                                    <TextBlock Text="{Binding TotalJobsCount}" Classes="metric-value" />
                                                </StackPanel>
                                            </Border>
                                            <Border Grid.Column="1" Classes="xp-summary">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="{Binding Texts[JobsSummaryActive]}" Classes="metric-caption" />
                                                    <TextBlock Text="{Binding ActiveStatesCount}" Classes="metric-value" />
                                                </StackPanel>
                                            </Border>
                                            <Border Grid.Column="2" Classes="xp-summary">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="{Binding Texts[StateBlockedCountLabel]}" Classes="metric-caption" />
                                                    <TextBlock Text="{Binding BlockedStatesCount}" Classes="metric-value" />
                                                </StackPanel>
                                            </Border>
                                            <Border Grid.Column="3" Classes="xp-summary">
                                                <StackPanel Spacing="4">
                                                    <TextBlock Text="{Binding Texts[StateErrorCountLabel]}" Classes="metric-caption" />
                                                    <TextBlock Text="{Binding ErrorStatesCount}" Classes="metric-value" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <Border Classes="xp-card" Padding="10">
                                            <Grid ColumnDefinitions="1.15*,0.8*,0.8*,0.8*,1*,1*,1.5*,1.5*" ColumnSpacing="10">
                                                <TextBlock Text="{Binding Texts[ColumnName]}" Classes="label" />
                                                <TextBlock Grid.Column="1" Text="{Binding Texts[StateLabel]}" Classes="label" />
                                                <TextBlock Grid.Column="2" Text="{Binding Texts[ProgressLabel]}" Classes="label" />
                                                <TextBlock Grid.Column="3" Text="{Binding Texts[RemainingFilesMetric]}" Classes="label" />
                                                <TextBlock Grid.Column="4" Text="{Binding Texts[TotalSizeMetric]}" Classes="label" />
                                                <TextBlock Grid.Column="5" Text="{Binding Texts[RemainingSizeMetric]}" Classes="label" />
                                                <TextBlock Grid.Column="6" Text="{Binding Texts[CurrentSourceLabel]}" Classes="label" />
                                                <TextBlock Grid.Column="7" Text="{Binding Texts[CurrentTargetLabel]}" Classes="label" />
                                            </Grid>
                                        </Border>

                                        <ListBox Classes="xp-list" ItemsSource="{Binding States}">
                                            <ListBox.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Classes="xp-row" Padding="10,8">
                                                        <Grid RowDefinitions="Auto,Auto" ColumnDefinitions="1.15*,0.8*,0.8*,0.8*,1*,1*,1.5*,1.5*" ColumnSpacing="10" RowSpacing="6">
                                                            <TextBlock Text="{Binding Name}" FontWeight="Bold" Foreground="#0043B0" />
                                                            <TextBlock Grid.Column="1" Text="{Binding State}" FontWeight="Bold" />
                                                            <StackPanel Grid.Column="2" Spacing="3">
                                                                <ProgressBar Minimum="0" Maximum="100" Value="{Binding Progression}" Height="16" />
                                                                <TextBlock Text="{Binding Progression, StringFormat='{}{0}%'}" Classes="caption" />
                                                            </StackPanel>
                                                            <TextBlock Grid.Column="3" Text="{Binding RemainingFiles}" />
                                                            <TextBlock Grid.Column="4" Text="{Binding TotalFilesSize}" />
                                                            <TextBlock Grid.Column="5" Text="{Binding RemainingSize}" />
                                                            <TextBlock Grid.Column="6" Text="{Binding CurrentSourceFilePath}" TextWrapping="Wrap" />
                                                            <TextBlock Grid.Column="7" Text="{Binding CurrentDestinationFilePath}" TextWrapping="Wrap" />
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ListBox.ItemTemplate>
                                        </ListBox>
                                    </StackPanel>

                                    <Border Grid.Row="3" Background="#ECE9D8" Padding="10,6" BorderBrush="#ACA899" BorderThickness="0,1,0,0">
                                        <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto" ColumnSpacing="10" RowSpacing="6">
                                            <TextBlock Text="{Binding Texts[StateFilePathLabel]}" Classes="caption" />
                                            <TextBlock Grid.Column="1" Text="{Binding StateFilePath}" Classes="caption" TextWrapping="Wrap" />
                                            <TextBlock Grid.Row="1" Text="{Binding Texts[SettingsFilePathLabel]}" Classes="caption" />
                                            <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding SettingsConfigPath}" Classes="caption" TextWrapping="Wrap" />
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="{Binding Texts[SettingsTab]}">
                    <ScrollViewer Margin="10">
                        <Grid>
                        <StackPanel Spacing="16" IsVisible="{Binding !IsSettingsGuideVisible}">
                            <Border Classes="xp-card" Padding="0" BorderBrush="#003399" BorderThickness="1">
                                <Grid RowDefinitions="Auto,*" Background="#ECE9D8">
                                    <Border Background="#0058E3" BorderBrush="#003399" BorderThickness="0,0,0,1" Padding="6,5">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                <TextBlock Text=">" Foreground="White" FontWeight="Bold" />
                                                <TextBlock Text="{Binding Texts[SettingsWindowTitle]}" Foreground="White" FontWeight="Bold" FontSize="13" />
                                            </StackPanel>
                                            <Button Grid.Column="1"
                                                    Content="{Binding Texts[SettingsApplyButton]}"
                                                    Command="{Binding SaveSettingsCommand}"
                                                    Classes="xp-primary"
                                                    Padding="10,3"
                                                    MinHeight="24" />
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Row="1" Margin="16" Spacing="14">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding Texts[SettingsPageTitle]}" Classes="section-title" />
                                            <TextBlock Text="{Binding Texts[SettingsPageSubtitle]}" Classes="caption" TextWrapping="Wrap" />
                                        </StackPanel>

                                        <Grid ColumnDefinitions="*,*" ColumnSpacing="14">
                                            <Border Classes="xp-panel">
                                                <StackPanel Spacing="12">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock Text="◌" Foreground="#0043B0" FontSize="16" />
                                                        <TextBlock Text="{Binding Texts[SettingsLocalizationTitle]}" Classes="panel-title" />
                                                    </StackPanel>

                                                    <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="10">
                                                        <TextBlock Text="{Binding Texts[LanguageLabel]}" Classes="label" />
                                                        <ComboBox Grid.Column="1"
                                                                  ItemsSource="{Binding LanguageOptions}"
                                                                  SelectedValue="{Binding SelectedLanguage}"
                                                                  SelectedValueBinding="{Binding Value}">
                                                            <ComboBox.ItemTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock Text="{Binding Label}" />
                                                                </DataTemplate>
                                                            </ComboBox.ItemTemplate>
                                                        </ComboBox>

                                                        <TextBlock Grid.Row="1" Text="{Binding Texts[LogFormatLabel]}" Classes="label" />
                                                        <ComboBox Grid.Row="1"
                                                                  Grid.Column="1"
                                                                  ItemsSource="{Binding LogFormatOptions}"
                                                                  SelectedValue="{Binding SelectedLogFormat}"
                                                                  SelectedValueBinding="{Binding Value}">
                                                            <ComboBox.ItemTemplate>
                                                                <DataTemplate>
                                                                    <TextBlock Text="{Binding Label}" />
                                                                </DataTemplate>
                                                            </ComboBox.ItemTemplate>
                                                        </ComboBox>

                                                        <Border Grid.Row="2" Grid.ColumnSpan="2" Classes="xp-card" Padding="8">
                                                            <TextBlock Text="{Binding Texts[SettingsLogHint]}" Classes="caption" TextWrapping="Wrap" Foreground="#0043B0" />
                                                        </Border>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="1" Classes="xp-panel">
                                                <StackPanel Spacing="12">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock Text="⌂" Foreground="#0043B0" FontSize="16" />
                                                        <TextBlock Text="{Binding Texts[SettingsPathsTitle]}" Classes="panel-title" />
                                                    </StackPanel>

                                                    <Grid RowDefinitions="Auto,Auto,Auto" RowSpacing="10">
                                                        <StackPanel Spacing="4">
                                                            <TextBlock Text="{Binding Texts[StateFilePathLabel]}" Classes="label" />
                                                            <TextBox Text="{Binding StateFilePath}" IsReadOnly="True" />
                                                        </StackPanel>

                                                        <StackPanel Grid.Row="1" Spacing="4">
                                                            <TextBlock Text="{Binding Texts[LogsDirectoryLabel]}" Classes="label" />
                                                            <TextBox Text="{Binding LogDirectoryPath}" IsReadOnly="True" />
                                                        </StackPanel>

                                                        <StackPanel Grid.Row="2" Spacing="4">
                                                            <TextBlock Text="{Binding Texts[SettingsFilePathLabel]}" Classes="label" />
                                                            <TextBox Text="{Binding SettingsConfigPath}" IsReadOnly="True" />
                                                        </StackPanel>
                                                    </Grid>
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                        <Border Classes="xp-panel">
                                            <StackPanel Spacing="12">
                                                <Grid ColumnDefinitions="*,Auto" ColumnSpacing="12">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock Text="⌐" Foreground="#BA1A1A" FontSize="16" />
                                                        <TextBlock Text="{Binding Texts[SettingsCryptoTitle]}" Classes="panel-title" />
                                                    </StackPanel>
                                                    <Border Grid.Column="1" Classes="xp-badge">
                                                        <TextBlock Text="{Binding Texts[SettingsEncryptionEnabled]}" FontWeight="Bold" Foreground="#003399" />
                                                    </Border>
                                                </Grid>

                                                <Grid ColumnDefinitions="1.2*,0.8*" ColumnSpacing="14">
                                                    <StackPanel Spacing="10">
                                                        <StackPanel Spacing="4">
                                                            <TextBlock Text="{Binding Texts[CryptoSoftPathLabel]}" Classes="label" />
                                                            <TextBox Text="{Binding CryptoSoftPath}" />
                                                        </StackPanel>

                                                        <StackPanel Spacing="4">
                                                            <TextBlock Text="{Binding Texts[CryptoKeyLabel]}" Classes="label" />
                                                            <TextBox Text="{Binding CryptoKey}" />
                                                        </StackPanel>
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1" Spacing="8">
                                                        <TextBlock Text="{Binding Texts[EncryptedExtensionsLabelShort]}" Classes="label" />
                                                        <TextBox Text="{Binding EncryptedExtensionsText}" AcceptsReturn="True" Height="52" TextWrapping="Wrap" />
                                                        <TextBlock Text="{Binding Texts[PriorityExtensionsLabelShort]}" Classes="label" />
                                                        <TextBox Text="{Binding PriorityExtensionsText}" AcceptsReturn="True" Height="52" TextWrapping="Wrap" />
                                                    </StackPanel>
                                                </Grid>

                                                <Border Classes="xp-card" Padding="8">
                                                    <TextBlock Text="{Binding Texts[SettingsCryptoBody]}" Classes="caption" TextWrapping="Wrap" />
                                                </Border>
                                            </StackPanel>
                                        </Border>

                                        <Grid ColumnDefinitions="1.15*,0.85*" ColumnSpacing="14">
                                            <Border Classes="xp-panel">
                                                <StackPanel Spacing="10">
                                                    <StackPanel Orientation="Horizontal" Spacing="8">
                                                        <TextBlock Text="!" Foreground="#0043B0" FontSize="16" />
                                                        <TextBlock Text="{Binding Texts[SettingsBusinessTitle]}" Classes="panel-title" />
                                                    </StackPanel>
                                                    <TextBlock Text="{Binding Texts[BusinessSoftwareLabel]}" Classes="label" />
                                                    <TextBox Text="{Binding BusinessSoftwareProcessesText}" AcceptsReturn="True" Height="72" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding Texts[LargeFileThresholdKoLabel]}" Classes="label" />
                                                    <TextBox Text="{Binding LargeFileThresholdKoText}" />
                                                    <TextBlock Text="{Binding Texts[SettingsBusinessBody]}" Classes="caption" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Border>

                                            <Border Grid.Column="1" BorderBrush="White" BorderThickness="2" Background="#0F4CA8" Padding="20">
                                                <StackPanel Spacing="8">
                                                    <TextBlock Text="{Binding Texts[SettingsHelpTitle]}" Foreground="White" FontWeight="Bold" FontSize="20" />
                                                    <TextBlock Text="{Binding Texts[SettingsHelpBody]}" Foreground="#DCE8FF" TextWrapping="Wrap" />
                                                    <Button Content="{Binding Texts[SettingsHelpFooter]}"
                                                            Command="{Binding ToggleSettingsGuideCommand}"
                                                            Padding="12,6"
                                                            HorizontalAlignment="Left" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>

                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>

                        <StackPanel Spacing="16" IsVisible="{Binding IsSettingsGuideVisible}">
                            <Border Classes="xp-card" Padding="0" BorderBrush="#BA1A1A" BorderThickness="2">
                                <Grid RowDefinitions="Auto,*" Background="#FFF8F7">
                                    <Border Background="#FFE5E3" BorderBrush="#BA1A1A" BorderThickness="0,0,0,1" Padding="10,8">
                                        <Grid ColumnDefinitions="*,Auto" ColumnSpacing="8">
                                            <TextBlock Text="{Binding Texts[SettingsGuideWindowTitle]}" FontWeight="Bold" Foreground="#BA1A1A" />
                                            <Button Grid.Column="1"
                                                    Content="{Binding Texts[BackButtonText]}"
                                                    Command="{Binding CloseSettingsGuideCommand}"
                                                    Padding="12,4" />
                                        </Grid>
                                    </Border>

                                    <StackPanel Grid.Row="1" Margin="14" Spacing="12">
                                        <StackPanel Spacing="4">
                                            <TextBlock Text="{Binding Texts[SettingsGuideTitle]}" Classes="section-title" />
                                            <TextBlock Text="{Binding Texts[SettingsGuideSubtitle]}" Classes="caption" TextWrapping="Wrap" />
                                        </StackPanel>

                                        <Border Classes="xp-helpbox" Padding="0">
                                            <Grid RowDefinitions="Auto,*">
                                                <Border Classes="xp-helpheader">
                                                    <TextBlock Text="{Binding Texts[SettingsGuideApplyTitle]}" FontWeight="Bold" Foreground="#BA1A1A" />
                                                </Border>
                                                <TextBlock Grid.Row="1" Margin="12" Text="{Binding Texts[SettingsGuideApplyBody]}" TextWrapping="Wrap" />
                                            </Grid>
                                        </Border>

                                        <Border Classes="xp-helpbox" Padding="0">
                                            <Grid RowDefinitions="Auto,*">
                                                <Border Classes="xp-helpheader">
                                                    <TextBlock Text="{Binding Texts[SettingsGuideLocalizationTitle]}" FontWeight="Bold" Foreground="#BA1A1A" />
                                                </Border>
                                                <StackPanel Grid.Row="1" Margin="12" Spacing="8">
                                                    <TextBlock Text="{Binding Texts[SettingsGuideLanguageBody]}" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding Texts[SettingsGuideLogFormatBody]}" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <Border Classes="xp-helpbox" Padding="0">
                                            <Grid RowDefinitions="Auto,*">
                                                <Border Classes="xp-helpheader">
                                                    <TextBlock Text="{Binding Texts[SettingsGuidePathsTitle]}" FontWeight="Bold" Foreground="#BA1A1A" />
                                                </Border>
                                                <StackPanel Grid.Row="1" Margin="12" Spacing="8">
                                                    <TextBlock Text="{Binding Texts[SettingsGuideStatePathBody]}" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding Texts[SettingsGuideLogsPathBody]}" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding Texts[SettingsGuideSettingsPathBody]}" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <Border Classes="xp-helpbox" Padding="0">
                                            <Grid RowDefinitions="Auto,*">
                                                <Border Classes="xp-helpheader">
                                                    <TextBlock Text="{Binding Texts[SettingsGuideCryptoTitle]}" FontWeight="Bold" Foreground="#BA1A1A" />
                                                </Border>
                                                <StackPanel Grid.Row="1" Margin="12" Spacing="8">
                                                    <TextBlock Text="{Binding Texts[SettingsGuideCryptoPathBody]}" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding Texts[SettingsGuideCryptoKeyBody]}" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding Texts[SettingsGuideExtensionsBody]}" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding Texts[SettingsGuidePriorityExtensionsBody]}" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding Texts[SettingsGuideLargeFileThresholdBody]}" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>

                                        <Border Classes="xp-helpbox" Padding="0">
                                            <Grid RowDefinitions="Auto,*">
                                                <Border Classes="xp-helpheader">
                                                    <TextBlock Text="{Binding Texts[SettingsGuideBusinessTitle]}" FontWeight="Bold" Foreground="#BA1A1A" />
                                                </Border>
                                                <TextBlock Grid.Row="1" Margin="12" Text="{Binding Texts[SettingsGuideBusinessBody]}" TextWrapping="Wrap" />
                                            </Grid>
                                        </Border>

                                        <Border Classes="xp-helpbox" Padding="0">
                                            <Grid RowDefinitions="Auto,*">
                                                <Border Classes="xp-helpheader">
                                                    <TextBlock Text="{Binding Texts[SettingsGuideBehaviorTitle]}" FontWeight="Bold" Foreground="#BA1A1A" />
                                                </Border>
                                                <StackPanel Grid.Row="1" Margin="12" Spacing="8">
                                                    <TextBlock Text="{Binding Texts[SettingsGuideBehaviorBody]}" TextWrapping="Wrap" />
                                                    <TextBlock Text="{Binding Texts[SettingsGuideReminderBody]}" TextWrapping="Wrap" />
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </StackPanel>
                        </Grid>
                    </ScrollViewer>
                </TabItem>

                <TabItem Header="{Binding Texts[AboutTab]}">
                    <ScrollViewer Margin="10">
                        <Grid HorizontalAlignment="Center" VerticalAlignment="Center">
                            <Border Width="520" Classes="xp-card" Padding="0" BorderBrush="#003399" BorderThickness="1">
                                <Grid RowDefinitions="Auto,*" Background="#ECE9D8">
                                    <Border Background="#0058E3" BorderBrush="#003399" BorderThickness="0,0,0,1" Padding="6,5">
                                        <Grid ColumnDefinitions="*,Auto">
                                            <StackPanel Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                                                <TextBlock Text="i" Foreground="White" FontWeight="Bold" />
                                                <TextBlock Text="{Binding Texts[AboutWindowTitle]}" Foreground="White" FontWeight="Bold" FontSize="13" />
                                            </StackPanel>
                                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="4">
                                                <Border Width="21" Height="21" Background="#2769E5" BorderBrush="#FFFFFF66" BorderThickness="1">
                                                    <TextBlock Text="_" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" />
                                                </Border>
                                                <Border Width="21" Height="21" Background="#E81123" BorderBrush="#FFFFFF66" BorderThickness="1">
                                                    <TextBlock Text="X" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center" FontSize="10" FontWeight="Bold" />
                                                </Border>
                                            </StackPanel>
                                        </Grid>
                                    </Border>

                                    <Grid Grid.Row="1" ColumnDefinitions="Auto,*" ColumnSpacing="18" Margin="16">
                                        <Border Width="74" Height="74" Classes="xp-card" Padding="0">
                                            <TextBlock Text="⟳" Foreground="#0043B0" FontSize="40" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                        </Border>

                                        <StackPanel Grid.Column="1" Spacing="12">
                                            <StackPanel Spacing="2">
                                                <TextBlock Text="{Binding Texts[AboutProductValue]}" Foreground="#0043B0" FontWeight="Bold" FontSize="20" />
                                                <TextBlock Text="{Binding Texts[AboutVersionBuildValue]}" Foreground="#1D5CB6" FontWeight="Bold" />
                                            </StackPanel>

                                            <Border Classes="xp-notepad" Padding="10">
                                                <Grid ColumnDefinitions="Auto,*" RowDefinitions="Auto,Auto,Auto" ColumnSpacing="10" RowSpacing="8">
                                                    <TextBlock Text="{Binding Texts[AboutStackLabel]}" Classes="caption" />
                                                    <TextBlock Grid.Column="1" Text="{Binding Texts[AboutStackValue]}" FontWeight="Bold" />
                                                    <TextBlock Grid.Row="1" Text="{Binding Texts[AboutUiLabel]}" Classes="caption" />
                                                    <TextBlock Grid.Row="1" Grid.Column="1" Text="{Binding Texts[AboutUiValue]}" FontWeight="Bold" />
                                                    <TextBlock Grid.Row="2" Text="{Binding Texts[AboutArchLabel]}" Classes="caption" />
                                                    <TextBlock Grid.Row="2" Grid.Column="1" Text="{Binding Texts[AboutArchValue]}" FontWeight="Bold" />
                                                </Grid>
                                            </Border>

                                            <StackPanel Spacing="6">
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="$" Foreground="#0043B0" FontWeight="Bold" />
                                                    <TextBlock Text="{Binding Texts[AboutPriceValue]}" FontWeight="Bold" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="*" Foreground="#1D5CB6" FontWeight="Bold" />
                                                    <TextBlock Text="{Binding Texts[AboutMaintenanceValue]}" Classes="caption" />
                                                </StackPanel>
                                            </StackPanel>

                                            <TextBlock Text="{Binding Texts[AboutCopyrightNotice]}" Classes="caption" TextWrapping="Wrap" FontStyle="Italic" />

                                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                                <Button Content="{Binding Texts[AboutOkButton]}" Padding="20,6" />
                                            </StackPanel>
                                        </StackPanel>
                                    </Grid>
                                </Grid>
                            </Border>
                        </Grid>
                    </ScrollViewer>
                </TabItem>
            </TabControl>
        </Border>

        <Border Grid.Row="2" Classes="xp-statusbar" Margin="12,0,12,12">
            <Grid ColumnDefinitions="1.6*,0.7*,0.7*,1.2*" ColumnSpacing="10">
                <TextBlock Text="{Binding StatusMessage}" />
                <TextBlock Grid.Column="1" Text="{Binding CurrentLanguageLabel}" />
                <TextBlock Grid.Column="2" Text="{Binding CurrentLogFormatLabel}" />
                <TextBlock Grid.Column="3" Text="{Binding BusinessSoftwareSummary}" TextWrapping="Wrap" />
            </Grid>
        </Border>
    </Grid>
</Window>
